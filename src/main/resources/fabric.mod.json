{
  "schemaVersion": 1,
  "id": "thm-addons",
  "version": "${version}",
  "name": "THM Addon",
  "description": "Addon for Meteor Client",
  "authors": [
    "Leonn170709"
  ],
  "contact": {
    "repo": "https://github.com/Leonn170709/THM-Addons"
  },
  "icon": "assets/icon/icon.png",
  "environment": "client",
  "entrypoints": {
    "meteor": [
      "xyz.thm.addon.THMAddon"
    ]
  },
  "mixins": [
    "thm-addon.mixins.json"
  ],
  "custom": {
    "meteor-client:color": "0,255,255",
    "thm-addon:commit": "${commit}"
  },
  "depends": {
    "java": ">=21",
    "minecraft": ["${mc_version}"],
    "meteor-client": "*"
  }
}
